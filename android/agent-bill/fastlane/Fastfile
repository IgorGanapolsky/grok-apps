default_platform(:android)

# Mirrors Random-Timer/native-android/fastlane/Fastfile conventions.
# AgentBill = com.iganapolsky.agentbill

platform :android do
  desc "Upload AAB to internal track"
  lane :internal do
    upload_to_play_store(
      package_name: "com.iganapolsky.agentbill",
      track: "internal",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true,
    )
  end

  desc "Upload AAB to closed (alpha) testing track"
  lane :closed do
    upload_to_play_store(
      package_name: "com.iganapolsky.agentbill",
      track: "alpha",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Promote internal to production"
  lane :promote do
    upload_to_play_store(
      package_name: "com.iganapolsky.agentbill",
      track: "internal",
      track_promote_to: "production",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Clean + build release AAB + upload to internal track"
  lane :ship_internal do
    setup_ci if ENV["CI"]
    gradle(task: "clean bundleRelease", project_dir: ".")
    internal
  end
end
