default_platform(:android)

platform :android do
  desc "Upload metadata (screenshots, descriptions, icon) to Google Play"
  lane :metadata do |_options|
    sh("python3 #{File.expand_path('../scripts/sync_metadata.py', __dir__)}")
  end

  desc "Upload AAB to internal track"
  lane :internal do
    upload_to_play_store(
      package_name: "com.iganapolsky.agentbill",
      track: "internal",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end

  desc "Ship it all"
  lane :ship do
    metadata
    internal
  end
end
